{
  "name": "react-ssr-template",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "rimraf dist && npm run dev:server && npm run dev:client && node ./dist/server/server",
    "dev:server": "cross-env TS_NODE_PROJECT=\"tsconfigr-webpack.json\" webpack --config config/server.dev.ts --stats=errors-only",
    "dev:client": "cross-env TS_NODE_PROJECT=\"tsconfigr-webpack.json\" webpack --config config/client.dev.ts --stats=errors-only",
    "build": "npm run build:client && npm run build:server",
    "build:server": "cross-env TS_NODE_PROJECT=\"tsconfigr-webpack.json\" webpack --config config/server.prod.ts",
    "build:client": "cross-env TS_NODE_PROJECT=\"tsconfigr-webpack.json\" webpack --config config/client.prod.ts"
  },
  "author": "蔡旻勲",
  "license": "MIT",
  "dependencies": {
    "@svgr/webpack": "^8.1.0",
    "@tailwindcss/postcss": "^4.2.2",
    "babel-plugin-named-asset-import": "^0.3.8",
    "express": "^5.2.1",
    "express-manifest-helpers": "^0.6.0",
    "i18next": "^26.0.3",
    "immer": "^11.1.4",
    "postcss": "^8.5.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.2",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.14.0",
    "redux": "^5.0.1",
    "redux-saga": "^1.4.2",
    "reselect": "^5.1.1",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-redux": "^7.1.34",
    "@types/react-router-dom": "^5.3.3",
    "@types/webpack": "^5.28.5",
    "@types/webpack-env": "^1.18.8",
    "@types/webpack-hot-middleware": "^2.25.12",
    "babel-loader": "^10.1.1",
    "core-js": "^3.49.0",
    "cross-env": "^10.1.0",
