    "regenerator-runtime": "^0.14.1",
    "rimraf": "^6.1.3",
    "style-loader": "^4.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.2",
    "url": "^0.11.4",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2",
    "webpack-dev-middleware": "^8.0.3",
    "webpack-hot-middleware": "^2.26.1",
    "webpack-manifest-plugin": "^6.0.1",
    "webpack-merge": "^6.0.1",
    "webpack-node-externals": "^3.0.0"
  }
